{
  "name": "waves",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main/dist/index.cjs",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently -n vite,electron \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.waves.app",
    "productName": "Waves",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "files": [
      "main/dist/**/*",
      "dist/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "../build/wavesd",
        "to": "wavesd"
      },
      {
        "from": "../build/waves-audio",
        "to": "waves-audio"
      }
    ]
  },
  "dependencies": {
    "@tanstack/react-router": "^1.166.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-devtools": "^1.166.2",
    "@tanstack/router-plugin": "^1.166.2",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
